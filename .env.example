# --- App ---
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000


# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000


# --- Database ---
DATABASE_PATH=backend/storage/veritrace.db


# --- Azure Document Intelligence ---
# Required for POST /api/verifications (real upload). When unset or
# USE_AZURE_DOC_INTEL=false, that endpoint returns 503 and the demo
# scenarios are unaffected. Do not commit real keys.
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=
AZURE_DOC_INTEL_MODEL_ID=prebuilt-layout
USE_AZURE_DOC_INTEL=true

# --- Azure OpenAI (unused; quota unavailable, GitHub Models is used instead) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview


# --- LLM explanation (GitHub Models) ---
# Set USE_LLM_EXPLANATION=true and provide a GITHUB_TOKEN to enable LLM
# rewriting of the verification summary/recommendation/reviewer_note.
# If anything is missing or the call fails, the deterministic template
# explanation is used automatically — verifications never fail because of LLM.
LLM_PROVIDER=github
GITHUB_TOKEN=
GITHUB_MODEL=gpt-4.1-mini
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference


# --- Misc ---
USE_LLM_EXPLANATION=true
USE_AZURE_DOC_INTEL=true
USE_AZURE_OPENAI=false
USE_DEMO_FALLBACK=true